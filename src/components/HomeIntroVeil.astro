<section class="home-intro is-loading" id="home-intro" aria-label="Peritissimus intro">
  <canvas class="home-intro-canvas" id="home-intro-canvas" aria-hidden="true"></canvas>

  <div class="home-intro-atmosphere" aria-hidden="true"></div>
  <div class="home-intro-vignette" aria-hidden="true"></div>
  <div class="home-intro-paper" aria-hidden="true"></div>
  <div class="home-intro-lens" aria-hidden="true"></div>
  <div class="home-intro-loader" id="home-intro-loader" aria-hidden="true">
    <span></span>
    <span></span>
  </div>

  <button
    class="home-intro-enter"
    id="home-intro-enter"
    type="button"
    aria-label="Enter terminal"
    disabled
  >
    <span class="home-intro-enter-mark" aria-hidden="true">
      <span></span>
      <span></span>
    </span>
  </button>
</section>

<script>
  import { createRafDriver, getProject, types } from '@theatre/core';
  import * as THREE from 'three';

  const INTRO_ID = 'home-intro';
  const CANVAS_ID = 'home-intro-canvas';
  const ENTER_ID = 'home-intro-enter';
  const REDUCED_MOTION = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const SCROLL_REVEAL_DISTANCE = REDUCED_MOTION ? 260 : 860;
  const TOUCH_REVEAL_DISTANCE = REDUCED_MOTION ? 220 : 720;
  const KEYBOARD_REVEAL_STEP = REDUCED_MOTION ? 1 : 0.24;
  const REVEAL_COMPLETE_THRESHOLD = 0.995;
  const INTRO_PIXEL_RATIO = 1;
  const THEATRE_PROJECT_ID = 'Artifex Home Intro';
  const THEATRE_SHEET_ID = 'Intro Veil';
  const THEATRE_OBJECT_KEY = 'Choreography';
  const THEATRE_REVEAL_SECONDS = 2.2;
  const THEATRE_VISIBLE_END_SECONDS = 1.84;
  const THEATRE_PERSISTENCE_KEY = 'artifex:home-intro-theatre';
  const ENABLE_THEATRE_STUDIO =
    import.meta.env.DEV && new URLSearchParams(window.location.search).has('theatre');

  type IntroVisual = {
    move: (event: PointerEvent) => void;
    ready: () => boolean;
    setRevealOrigin: (x: number, y: number) => void;
    setRevealProgress: (progress: number) => void;
    destroy: () => void;
  };

  type ImageLayerSpec = {
    key: string;
    url: string;
    aspect: number;
    kind: 'cover' | 'sprite';
    opacity: number;
    widthDesktop: number;
    widthMobile: number;
    xDesktop: number;
    yDesktop: number;
    xMobile: number;
    yMobile: number;
    rotation: number;
    parallax: number;
    lift: number;
    seed: number;
    revealX: number;
    revealY: number;
    revealRotation: number;
    revealScale: number;
  };

  type ImageLayer = {
    mesh: THREE.Mesh<THREE.PlaneGeometry, THREE.ShaderMaterial>;
    uniforms: Record<string, THREE.IUniform>;
    spec: ImageLayerSpec;
    baseX: number;
    baseY: number;
    baseScaleX: number;
    baseScaleY: number;
  };

  type ChoreographyState = {
    reveal: number;
    scatter: number;
    ember: number;
    atmosphere: number;
    grain: number;
  };

  type TheatreControls = {
    ready: Promise<void>;
    tick: (time: number) => void;
    setProgress: (progress: number) => void;
    destroy: () => void;
  };

  type TheatreStudioWindow = Window & {
    __ARTIFEX_THEATRE_STUDIO__?: Promise<void>;
  };

  const THEATRE_STATE = {
    sheetsById: {
      [THEATRE_SHEET_ID]: {
        staticOverrides: { byObject: {} },
        sequence: {
          type: 'PositionalSequence',
          length: THEATRE_REVEAL_SECONDS,
          subUnitsPerUnit: 30,
          tracksByObject: {
            [THEATRE_OBJECT_KEY]: {
              trackIdByPropPath: {
                '["reveal"]': 'revealTrack',
                '["scatter"]': 'scatterTrack',
                '["ember"]': 'emberTrack',
                '["atmosphere"]': 'atmosphereTrack',
                '["grain"]': 'grainTrack',
              },
              trackData: {
                revealTrack: theatreTrack('Choreography:["reveal"]', [
                  [0, 0],
                  [0.19, 0.18],
                  [1.84, 1],
                  [2.2, 1],
                ]),
                scatterTrack: theatreTrack('Choreography:["scatter"]', [
                  [0, 0],
                  [0.19, 0.16],
                  [1.84, 1],
                  [2.2, 1],
                ]),
                emberTrack: theatreTrack('Choreography:["ember"]', [
                  [0, 0],
                  [0.19, 0.82],
                  [0.78, 0.72],
                  [1.76, 0],
                  [2.2, 0],
                ]),
                atmosphereTrack: theatreTrack('Choreography:["atmosphere"]', [
                  [0, 1],
                  [0.62, 1],
                  [1.82, 0],
                  [2.2, 0],
                ]),
                grainTrack: theatreTrack('Choreography:["grain"]', [
                  [0, 1],
                  [0.62, 1],
                  [1.82, 0],
                  [2.2, 0],
                ]),
              },
            },
          },
        },
      },
    },
    definitionVersion: '0.4.0',
    revisionHistory: ['artifex-home-intro-v1'],
  };

  const IMAGE_LAYERS: ImageLayerSpec[] = [
    {
      key: 'background',
      url: '/home-intro-sunny-bg.webp',
      aspect: 16 / 9,
      kind: 'cover',
      opacity: 1,
      widthDesktop: 1,
      widthMobile: 1,
      xDesktop: 0,
      yDesktop: 0,
      xMobile: 0,
      yMobile: 0,
      rotation: 0,
      parallax: 0.018,
      lift: 0,
      seed: 1.7,
      revealX: 0,
      revealY: 0,
      revealRotation: 0,
      revealScale: 0.08,
    },
    {
      key: 'keyboard',
      url: '/home-intro-keyboard.webp',
      aspect: 1,
      kind: 'sprite',
      opacity: 1,
      widthDesktop: 0.23,
      widthMobile: 0.5,
      xDesktop: -0.03,
      yDesktop: 0.24,
      xMobile: 0,
      yMobile: 0.18,
      rotation: -0.075,
      parallax: 0.14,
      lift: 0.04,
      seed: 23.6,
      revealX: -0.32,
      revealY: 0.34,
      revealRotation: -0.2,
      revealScale: 0.18,
    },
    {
      key: 'drift',
      url: '/home-intro-drift.webp',
      aspect: 1.5,
      kind: 'sprite',
      opacity: 0.68,
      widthDesktop: 1.12,
      widthMobile: 1.46,
      xDesktop: 0.01,
      yDesktop: 0.08,
      xMobile: 0,
      yMobile: 0.04,
      rotation: 0.015,
      parallax: 0.18,
      lift: 0,
      seed: 42.8,
      revealX: 0.18,
      revealY: 0.16,
      revealRotation: 0.08,
      revealScale: 0.06,
    },
    {
      key: 'foreground',
      url: '/home-intro-foreground.webp',
      aspect: 1.5,
      kind: 'sprite',
      opacity: 0.98,
      widthDesktop: 1.08,
      widthMobile: 1.34,
      xDesktop: 0,
      yDesktop: -0.54,
      xMobile: 0,
      yMobile: -0.52,
      rotation: 0,
      parallax: 0.045,
      lift: 0.02,
      seed: 31.8,
      revealX: -0.14,
      revealY: -0.42,
      revealRotation: -0.06,
      revealScale: 0.08,
    },
  ];

  function theatreTrack(debugName: string, points: Array<[number, number]>) {
    const trackId = debugName.toLowerCase().replace(/[^a-z0-9]+/g, '-');

    return {
      type: 'BasicKeyframedTrack',
      __debugName: debugName,
      keyframes: points.map(([position, value], index) => ({
        id: `${trackId}-${index}`,
        position,
        connectedRight: index < points.length - 1,
        handles: [0.5, 1, 0.5, 0],
        value,
      })),
    };
  }

  function initializeTheatreStudio(rafDriver: ReturnType<typeof createRafDriver>) {
    if (!ENABLE_THEATRE_STUDIO) return Promise.resolve();

    const studioWindow = window as TheatreStudioWindow;
    if (!studioWindow.__ARTIFEX_THEATRE_STUDIO__) {
      studioWindow.__ARTIFEX_THEATRE_STUDIO__ = import('@theatre/studio').then(
        ({ default: studio }) => {
          studio.initialize({
            persistenceKey: THEATRE_PERSISTENCE_KEY,
            __experimental_rafDriver: rafDriver,
          });
        }
      );
    }

    return studioWindow.__ARTIFEX_THEATRE_STUDIO__;
  }

  function createTheatreControls(choreography: ChoreographyState): TheatreControls {
    const rafDriver = createRafDriver({ name: 'HomeIntroVeil' });
    let sheet: ReturnType<ReturnType<typeof getProject>['sheet']> | undefined;
    let unsubscribe: (() => void) | undefined;
    let progress = 0;

    function applyProgress(nextProgress: number) {
      progress = THREE.MathUtils.clamp(nextProgress, 0, 1);
      if (!sheet) {
        choreography.reveal = progress;
        choreography.scatter = progress;
        choreography.ember = progress < 1 ? Math.sin(progress * Math.PI) : 0;
        choreography.atmosphere = 1 - progress;
        choreography.grain = 1 - progress;
        return;
      }

      sheet.sequence.pause();
      sheet.sequence.position =
        progress >= REVEAL_COMPLETE_THRESHOLD
          ? THEATRE_REVEAL_SECONDS
          : progress * THEATRE_VISIBLE_END_SECONDS;
    }

    const ready = (async () => {
      await initializeTheatreStudio(rafDriver);

      const project = getProject(THEATRE_PROJECT_ID, { state: THEATRE_STATE });
      sheet = project.sheet(THEATRE_SHEET_ID);
      const object = sheet.object(
        THEATRE_OBJECT_KEY,
        {
          reveal: types.number(0, { range: [0, 1] }),
          scatter: types.number(0, { range: [0, 1] }),
          ember: types.number(0, { range: [0, 1] }),
          atmosphere: types.number(1, { range: [0, 1] }),
          grain: types.number(1, { range: [0, 1] }),
        },
        { reconfigure: true }
      );

      unsubscribe = object.onValuesChange((values) => {
        choreography.reveal = values.reveal;
        choreography.scatter = values.scatter;
        choreography.ember = values.ember;
        choreography.atmosphere = values.atmosphere;
        choreography.grain = values.grain;
      }, rafDriver);

      await project.ready;
      applyProgress(progress);
    })().catch((error) => {
      console.warn('Theatre.js intro choreography failed to initialize.', error);
    });

    return {
      ready,
      tick: (time) => rafDriver.tick(time),
      setProgress(nextProgress) {
        applyProgress(nextProgress);
      },
      destroy() {
        sheet?.sequence.pause();
        unsubscribe?.();
      },
    };
  }

  function bootIntro() {
    const root = document.getElementById(INTRO_ID) as HTMLElement | null;
    const canvas = document.getElementById(CANVAS_ID) as HTMLCanvasElement | null;
    const enter = document.getElementById(ENTER_ID) as HTMLButtonElement | null;
    if (!root || !canvas || !enter) return;

    const loader = {
      progress: Number(root.style.getPropertyValue('--loader-progress')) || 0,
    };
    let loaderAnimation = 0;

    function setLoaderProgress(progress: number, complete?: () => void) {
      window.cancelAnimationFrame(loaderAnimation);
      const from = loader.progress;
      const to = Math.max(loader.progress, progress);
      const start = performance.now();
      const duration = REDUCED_MOTION ? 120 : 320;

      function tick(now: number) {
        const t = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - t, 3);
        loader.progress = from + (to - from) * eased;
        root.style.setProperty('--loader-progress', loader.progress.toFixed(4));
        if (t < 1) {
          loaderAnimation = window.requestAnimationFrame(tick);
        } else {
          root.style.setProperty('--loader-progress', loader.progress.toFixed(4));
          complete?.();
        }
      }

      loaderAnimation = window.requestAnimationFrame(tick);
    }

    enter.disabled = true;
    const visual = createIntroScene(
      root,
      canvas,
      (progress) => {
        setLoaderProgress(progress);
      },
      () => {
        setLoaderProgress(1, () => {
          root.classList.remove('is-loading');
          root.classList.add('is-ready');
          enter.disabled = false;
        });
      }
    );
    let revealProgress = 0;
    let disposeTimer = 0;
    let touchLastY = 0;
    let touchActive = false;
    let revealCommitted = false;
    let visualDisposed = false;

    function disposeVisual() {
      if (visualDisposed) return;
      visualDisposed = true;
      visual.destroy();
    }

    function disposeVisualAfterReveal() {
      const idleWindow = window as Window & {
        requestIdleCallback?: (callback: () => void, options?: { timeout: number }) => number;
      };

      if (idleWindow.requestIdleCallback) {
        idleWindow.requestIdleCallback(disposeVisual, { timeout: 700 });
        return;
      }

      disposeTimer = window.setTimeout(disposeVisual, 80);
    }

    function setRevealOrigin(clientX: number, clientY: number) {
      const rect = root.getBoundingClientRect();
      const localX = THREE.MathUtils.clamp(clientX - rect.left, 0, rect.width);
      const localY = THREE.MathUtils.clamp(clientY - rect.top, 0, rect.height);

      root.style.setProperty('--reveal-x', `${localX}px`);
      root.style.setProperty('--reveal-y', `${localY}px`);
      visual.setRevealOrigin(localX / rect.width, 1 - localY / rect.height);
    }

    function setRevealOriginToCenter() {
      const rect = root.getBoundingClientRect();
      setRevealOrigin(rect.left + rect.width * 0.5, rect.top + rect.height * 0.5);
    }

    function writeRevealProgress(progress: number) {
      const opacity = 1 - progress;
      root.style.setProperty('--reveal-progress', progress.toFixed(4));
      root.style.setProperty('--reveal-opacity', opacity.toFixed(4));
      root.style.setProperty('--reveal-lines-opacity', (opacity * 0.22).toFixed(4));
      root.style.setProperty('--reveal-paper-opacity', (opacity * 0.07).toFixed(4));
      root.style.setProperty('--reveal-lens-opacity', (opacity * 0.18).toFixed(4));
    }

    function setRevealProgress(nextProgress: number) {
      if (!visual.ready() || revealCommitted) return;

      revealProgress = THREE.MathUtils.clamp(nextProgress, 0, 1);
      root.classList.toggle('is-scrubbing', revealProgress > 0);
      writeRevealProgress(revealProgress);
      visual.setRevealProgress(revealProgress);

      if (revealProgress >= REVEAL_COMPLETE_THRESHOLD) {
        commitReveal();
      }
    }

    function commitReveal() {
      if (revealCommitted) return;
      revealCommitted = true;
      revealProgress = 1;
      writeRevealProgress(1);
      root.classList.add('is-withering');
      visual.setRevealProgress(1);
      removeInputListeners();
      window.cancelAnimationFrame(loaderAnimation);
      root.remove();
      document.getElementById('agent-terminal-input')?.focus({ preventScroll: true });
      disposeVisualAfterReveal();
    }

    function handlePointerDown(event: PointerEvent) {
      if (!visual.ready() || revealCommitted) return;
      setRevealOrigin(event.clientX, event.clientY);
    }

    function handleWheel(event: WheelEvent) {
      if (!visual.ready() || revealCommitted) return;

      const rawDelta =
        Math.abs(event.deltaY) >= Math.abs(event.deltaX) ? event.deltaY : event.deltaX;
      if (rawDelta === 0) return;

      event.preventDefault();
      const deltaUnit = event.deltaMode === 1 ? 16 : event.deltaMode === 2 ? window.innerHeight : 1;
      setRevealOrigin(event.clientX, event.clientY);
      setRevealProgress(revealProgress + (rawDelta * deltaUnit) / SCROLL_REVEAL_DISTANCE);
    }

    function handleTouchStart(event: TouchEvent) {
      if (!visual.ready() || revealCommitted) return;
      const touch = event.touches[0];
      if (!touch) return;
      touchActive = true;
      touchLastY = touch.clientY;
      setRevealOrigin(touch.clientX, touch.clientY);
    }

    function handleTouchMove(event: TouchEvent) {
      if (!visual.ready() || revealCommitted || !touchActive) return;
      const touch = event.touches[0];
      if (!touch) return;

      const delta = touchLastY - touch.clientY;
      touchLastY = touch.clientY;
      if (delta === 0) return;

      event.preventDefault();
      setRevealOrigin(touch.clientX, touch.clientY);
      setRevealProgress(revealProgress + delta / TOUCH_REVEAL_DISTANCE);
    }

    function handleTouchEnd() {
      touchActive = false;
    }

    function handleKeydown(event: KeyboardEvent) {
      if (!visual.ready() || revealCommitted) return;

      if (event.key === 'Enter' || event.key === ' ' || event.key === 'ArrowDown') {
        event.preventDefault();
        setRevealOriginToCenter();
        setRevealProgress(revealProgress + KEYBOARD_REVEAL_STEP);
      } else if (event.key === 'ArrowUp') {
        event.preventDefault();
        setRevealOriginToCenter();
        setRevealProgress(revealProgress - KEYBOARD_REVEAL_STEP);
      }
    }

    function removeInputListeners() {
      root.removeEventListener('pointermove', visual.move);
      root.removeEventListener('pointerdown', handlePointerDown);
      root.removeEventListener('wheel', handleWheel);
      root.removeEventListener('touchstart', handleTouchStart);
      root.removeEventListener('touchmove', handleTouchMove);
      root.removeEventListener('touchend', handleTouchEnd);
      root.removeEventListener('touchcancel', handleTouchEnd);
      enter.removeEventListener('keydown', handleKeydown);
    }

    root.addEventListener('pointermove', visual.move);
    root.addEventListener('pointerdown', handlePointerDown);
    root.addEventListener('wheel', handleWheel, { passive: false });
    root.addEventListener('touchstart', handleTouchStart);
    root.addEventListener('touchmove', handleTouchMove, { passive: false });
    root.addEventListener('touchend', handleTouchEnd);
    root.addEventListener('touchcancel', handleTouchEnd);
    enter.addEventListener('keydown', handleKeydown);

    window.addEventListener(
      'pagehide',
      () => {
        window.clearTimeout(disposeTimer);
        window.cancelAnimationFrame(loaderAnimation);
        removeInputListeners();
        disposeVisual();
      },
      { once: true }
    );
  }

  function createIntroScene(
    root: HTMLElement,
    canvas: HTMLCanvasElement,
    onProgress: (progress: number) => void,
    onReady: () => void
  ): IntroVisual {
    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: false,
      powerPreference: 'high-performance',
    });
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.setClearColor(0x000000, 0);
    renderer.setPixelRatio(INTRO_PIXEL_RATIO);

    const scene = new THREE.Scene();
    const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, -10, 10);
    camera.position.z = 5;

    const choreography: ChoreographyState = {
      reveal: 0,
      scatter: 0,
      ember: 0,
      atmosphere: 1,
      grain: 1,
    };
    const theatre = createTheatreControls(choreography);

    let ready = false;
    const manager = new THREE.LoadingManager();
    manager.onProgress = (_url, loaded, total) => {
      onProgress(total > 0 ? loaded / total : 0);
    };
    manager.onLoad = () => {
      void theatre.ready.then(() => {
        renderer.compile(scene, camera);
        renderer.render(scene, camera);
        ready = true;
        onReady();
      });
    };
    manager.onError = () => {
      onProgress(1);
    };

    const textureLoader = new THREE.TextureLoader(manager);
    const textures: THREE.Texture[] = [];
    const layers: ImageLayer[] = [];
    const revealPoint = new THREE.Vector2(0.5, 0.5);
    const pointer = new THREE.Vector2(0, 0);
    const target = new THREE.Vector2(0, 0);

    for (const spec of IMAGE_LAYERS) {
      const texture = textureLoader.load(spec.url);
      texture.colorSpace = THREE.SRGBColorSpace;
      texture.anisotropy = Math.min(2, renderer.capabilities.getMaxAnisotropy());
      textures.push(texture);

      const uniforms = imageUniforms(texture, spec);
      const material = new THREE.ShaderMaterial({
        uniforms,
        vertexShader: IMAGE_VERTEX_SHADER,
        fragmentShader: IMAGE_FRAGMENT_SHADER,
        transparent: true,
        depthWrite: false,
        depthTest: false,
      });

      const segments = spec.kind === 'cover' ? 1 : 18;
      const mesh = new THREE.Mesh(new THREE.PlaneGeometry(1, 1, segments, segments), material);
      mesh.renderOrder =
        spec.kind === 'cover'
          ? 1
          : spec.key === 'foreground'
            ? 7
            : spec.key === 'drift'
              ? 6
              : spec.key === 'keyboard'
                ? 5
                : 4;
      scene.add(mesh);
      layers.push({ mesh, uniforms, spec, baseX: 0, baseY: 0, baseScaleX: 1, baseScaleY: 1 });
    }

    const atmosphere = buildAtmospherePlane();
    const particles = buildShaderParticles(REDUCED_MOTION ? 90 : 240);
    scene.add(atmosphere.mesh, particles.points);

    let width = 1;
    let height = 1;
    let viewWidth = 2;
    let viewHeight = 2;
    let raf = 0;
    let startedAt = performance.now();
    let disposed = false;

    function resize() {
      const rect = root.getBoundingClientRect();
      width = Math.max(1, Math.floor(rect.width));
      height = Math.max(1, Math.floor(rect.height));
      const aspect = width / height;
      viewWidth = 2 * aspect;
      viewHeight = 2;

      renderer.setSize(width, height, false);
      camera.left = -aspect;
      camera.right = aspect;
      camera.top = 1;
      camera.bottom = -1;
      camera.updateProjectionMatrix();

      for (const layer of layers) layoutLayer(layer, aspect, viewWidth, viewHeight);
      atmosphere.mesh.scale.set(viewWidth, viewHeight, 1);
      particles.uniforms.uPixelRatio.value = INTRO_PIXEL_RATIO;
    }

    function move(event: PointerEvent) {
      const rect = root.getBoundingClientRect();
      target.x = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
      target.y = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
    }

    function setRevealOrigin(x: number, y: number) {
      revealPoint.set(x, y);
    }

    function setRevealProgress(progress: number) {
      theatre.setProgress(progress);
    }

    function animate() {
      if (disposed) return;
      raf = window.requestAnimationFrame(animate);

      const now = performance.now();
      theatre.tick(now);
      const t = (now - startedAt) * 0.001;
      const revealT = choreography.reveal;
      const scatterT = choreography.scatter;

      pointer.lerp(target, 0.055);

      for (const layer of layers) {
        const { mesh, uniforms, spec } = layer;
        const isDriftLayer = spec.key === 'drift';
        const isKeyboardLayer = spec.key === 'keyboard';
        const layerRevealT = isKeyboardLayer
          ? THREE.MathUtils.clamp((revealT - 0.08) / 0.92, 0, 1)
          : revealT;
        const layerScatterT = isKeyboardLayer
          ? THREE.MathUtils.clamp((scatterT - 0.05) / 0.95, 0, 1)
          : scatterT;
        uniforms.uTime.value = t;
        uniforms.uReveal.value = layerRevealT;
        uniforms.uEmber.value = choreography.ember;
        uniforms.uGrain.value = choreography.grain;
        uniforms.uRevealPoint.value.copy(revealPoint);
        uniforms.uPointer.value.copy(pointer);
        uniforms.uResolution.value.set(width, height);

        const revealX = spec.revealX * layerScatterT * viewWidth * 0.24;
        const revealY = spec.revealY * layerScatterT * viewHeight * 0.3;
        const parallaxX = pointer.x * spec.parallax * viewWidth * 0.06;
        const parallaxY = -pointer.y * spec.parallax * viewHeight * 0.05;
        const breezeX =
          Math.cos(t * (isDriftLayer ? 0.2 : 0.16) + spec.seed) *
          (isDriftLayer ? 0.045 : isKeyboardLayer ? 0.012 : 0) *
          choreography.atmosphere;
        const floatY =
          Math.sin(t * 0.45 + spec.seed) *
          (spec.kind === 'cover' ? 0.004 : isKeyboardLayer ? 0.022 : isDriftLayer ? 0.028 : 0.012) *
          choreography.atmosphere;
        const scale =
          1 +
          layerScatterT * spec.revealScale +
          Math.sin(t * 0.23 + spec.seed) *
            (isKeyboardLayer ? 0.011 : 0.006) *
            choreography.atmosphere;

        mesh.position.set(
          layer.baseX + parallaxX + revealX + breezeX,
          layer.baseY + parallaxY + revealY + floatY,
          0
        );
        mesh.rotation.z =
          spec.rotation +
          spec.revealRotation * layerScatterT +
          pointer.x * spec.parallax * 0.08 +
          Math.sin(t * 0.18 + spec.seed) * (isDriftLayer ? 0.018 : isKeyboardLayer ? 0.006 : 0);
        mesh.scale.set(layer.baseScaleX * scale, layer.baseScaleY * scale, 1);
      }

      atmosphere.uniforms.uTime.value = t;
      atmosphere.uniforms.uReveal.value = revealT;
      atmosphere.uniforms.uOpacity.value = choreography.atmosphere;
      atmosphere.uniforms.uRevealPoint.value.copy(revealPoint);
      atmosphere.uniforms.uPointer.value.copy(pointer);
      particles.uniforms.uTime.value = t;
      particles.uniforms.uReveal.value = revealT;
      particles.uniforms.uEmber.value = choreography.ember;

      renderer.render(scene, camera);
    }

    resize();
    window.addEventListener('resize', resize);
    animate();

    return {
      move,
      ready: () => ready,
      setRevealOrigin,
      setRevealProgress,
      destroy() {
        if (disposed) return;
        disposed = true;
        theatre.destroy();
        window.cancelAnimationFrame(raf);
        window.removeEventListener('resize', resize);
        scene.traverse((object) => {
          if (object instanceof THREE.Mesh || object instanceof THREE.Points) {
            object.geometry.dispose();
            const materials = Array.isArray(object.material) ? object.material : [object.material];
            for (const material of materials) material.dispose();
          }
        });
        for (const texture of textures) texture.dispose();
        renderer.dispose();
      },
    };
  }

  function imageUniforms(
    texture: THREE.Texture,
    spec: ImageLayerSpec
  ): Record<string, THREE.IUniform> {
    return {
      uTexture: { value: texture },
      uTime: { value: 0 },
      uReveal: { value: 0 },
      uEmber: { value: 0 },
      uGrain: { value: 1 },
      uRevealPoint: { value: new THREE.Vector2(0.5, 0.5) },
      uResolution: { value: new THREE.Vector2(1, 1) },
      uPointer: { value: new THREE.Vector2(0, 0) },
      uOpacity: { value: spec.opacity },
      uSeed: { value: spec.seed },
      uLift: { value: spec.lift },
      uIsBackground: { value: spec.kind === 'cover' ? 1 : 0 },
    };
  }

  function layoutLayer(
    layer: ImageLayer,
    viewportAspect: number,
    worldWidth: number,
    worldHeight: number
  ) {
    const { mesh, spec } = layer;
    const mobile = viewportAspect < 0.78;

    if (spec.kind === 'cover') {
      const overscan = 1.08;
      let scaleX = worldWidth * overscan;
      let scaleY = scaleX / spec.aspect;
      if (scaleY < worldHeight * overscan) {
        scaleY = worldHeight * overscan;
        scaleX = scaleY * spec.aspect;
      }
      layer.baseX = 0;
      layer.baseY = 0;
      layer.baseScaleX = scaleX;
      layer.baseScaleY = scaleY;
      mesh.scale.set(scaleX, scaleY, 1);
      mesh.position.set(0, 0, 0);
      return;
    }

    const widthRatio = mobile ? spec.widthMobile : spec.widthDesktop;
    const xRatio = mobile ? spec.xMobile : spec.xDesktop;
    const yRatio = mobile ? spec.yMobile : spec.yDesktop;
    const scaleX = worldWidth * widthRatio;
    const scaleY = scaleX / spec.aspect;

    layer.baseX = worldWidth * xRatio;
    layer.baseY = worldHeight * yRatio;
    layer.baseScaleX = scaleX;
    layer.baseScaleY = scaleY;
    mesh.scale.set(scaleX, scaleY, 1);
    mesh.position.set(layer.baseX, layer.baseY, 0);
    mesh.rotation.z = spec.rotation;
  }

  function buildAtmospherePlane() {
    const uniforms = {
      uTime: { value: 0 },
      uReveal: { value: 0 },
      uOpacity: { value: 1 },
      uRevealPoint: { value: new THREE.Vector2(0.5, 0.5) },
      uPointer: { value: new THREE.Vector2(0, 0) },
    };
    const mesh = new THREE.Mesh(
      new THREE.PlaneGeometry(1, 1, 1, 1),
      new THREE.ShaderMaterial({
        uniforms,
        vertexShader: ATMOSPHERE_VERTEX_SHADER,
        fragmentShader: ATMOSPHERE_FRAGMENT_SHADER,
        transparent: true,
        depthWrite: false,
        depthTest: false,
        blending: THREE.AdditiveBlending,
      })
    );
    mesh.renderOrder = 8;
    return { mesh, uniforms };
  }

  function buildShaderParticles(count: number) {
    const positions = new Float32Array(count * 3);
    const velocities = new Float32Array(count * 3);
    const sizes = new Float32Array(count);
    const seeds = new Float32Array(count);

    for (let i = 0; i < count; i++) {
      const ix = i * 3;
      positions[ix] = -1.8 + Math.random() * 3.6;
      positions[ix + 1] = -1.05 + Math.random() * 2.1;
      positions[ix + 2] = 0;
      velocities[ix] = (Math.random() - 0.5) * 1.9;
      velocities[ix + 1] = (Math.random() - 0.25) * 1.4;
      velocities[ix + 2] = 0;
      sizes[i] = 1.4 + Math.random() * 3.8;
      seeds[i] = Math.random() * 100;
    }

    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    geometry.setAttribute('aVelocity', new THREE.BufferAttribute(velocities, 3));
    geometry.setAttribute('aSize', new THREE.BufferAttribute(sizes, 1));
    geometry.setAttribute('aSeed', new THREE.BufferAttribute(seeds, 1));

    const uniforms = {
      uTime: { value: 0 },
      uReveal: { value: 0 },
      uEmber: { value: 0 },
      uPixelRatio: { value: INTRO_PIXEL_RATIO },
    };

    const points = new THREE.Points(
      geometry,
      new THREE.ShaderMaterial({
        uniforms,
        vertexShader: PARTICLE_VERTEX_SHADER,
        fragmentShader: PARTICLE_FRAGMENT_SHADER,
        transparent: true,
        depthWrite: false,
        depthTest: false,
        blending: THREE.AdditiveBlending,
      })
    );
    points.renderOrder = 9;
    return { points, uniforms };
  }

  const IMAGE_VERTEX_SHADER = `
    precision mediump float;
    varying vec2 vUv;
    varying vec2 vScreen;
    uniform float uTime;
    uniform float uReveal;
    uniform vec2 uPointer;
    uniform float uSeed;

    void main() {
      vUv = uv;
      vec3 pos = position;
      float warp = sin((position.x + uTime * 0.18 + uSeed) * 5.0) * 0.006;
      pos.z += warp * (1.0 - uReveal);
      pos.x += uPointer.x * 0.006 * (1.0 - uReveal);
      pos.y -= uPointer.y * 0.004 * (1.0 - uReveal);
      vec4 projected = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
      vScreen = projected.xy / projected.w * 0.5 + 0.5;
      gl_Position = projected;
    }
  `;

  const IMAGE_FRAGMENT_SHADER = `
    precision mediump float;
    uniform sampler2D uTexture;
    uniform float uTime;
    uniform float uReveal;
    uniform float uEmber;
    uniform float uGrain;
    uniform vec2 uRevealPoint;
    uniform vec2 uResolution;
    uniform float uOpacity;
    uniform float uSeed;
    uniform float uLift;
    uniform int uIsBackground;
    varying vec2 vUv;
    varying vec2 vScreen;

    float hash(vec2 p) {
      p = fract(p * vec2(123.34, 456.21));
      p += dot(p, p + 45.32);
      return fract(p.x * p.y);
    }

    float noise(vec2 p) {
      vec2 i = floor(p);
      vec2 f = fract(p);
      f = f * f * (3.0 - 2.0 * f);
      float a = hash(i);
      float b = hash(i + vec2(1.0, 0.0));
      float c = hash(i + vec2(0.0, 1.0));
      float d = hash(i + vec2(1.0, 1.0));
      return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
    }

    float fbm(vec2 p) {
      return noise(p) * 0.65 + noise(p * 2.03 + 17.19) * 0.35;
    }

    void main() {
      vec2 uv = vUv;
      float paper = 0.5;
      if (uIsBackground == 0) {
        paper = fbm(uv * 5.0 + uSeed * 0.07);
      }
      float ripple = (paper - 0.5) * 0.008 * (1.0 - uReveal);
      if (uIsBackground == 0) {
        uv += vec2(ripple, -ripple * 0.45);
      }

      vec4 tex = texture2D(uTexture, uv);
      float sourceAlpha = uIsBackground == 1 ? 1.0 : tex.a;
      if (sourceAlpha < 0.015) discard;

      float dissolveNoise = 0.0;
      if (uReveal > 0.001) {
        dissolveNoise = uIsBackground == 1
          ? noise(vScreen * 6.5 + vec2(uSeed, uTime * 0.045))
          : fbm(vScreen * 9.5 + vec2(uSeed, uTime * 0.075));
      }
      float fineNoise = uGrain > 0.001 ? hash(gl_FragCoord.xy + uSeed + uTime) : 0.5;
      float radius = uReveal * 1.48;
      float wind = sin((vScreen.x * 3.8 + vScreen.y * 1.4 + uTime * 0.22 + uSeed) * 3.14159) * 0.026;
      float field = distance(vScreen, uRevealPoint) + dissolveNoise * 0.17 + wind - uReveal * 0.035;
      float outsideReveal = smoothstep(radius - 0.17, radius + 0.068, field);
      float revealMix = smoothstep(0.015, 0.12, uReveal);
      float visible = mix(1.0, outsideReveal, revealMix);
      float ember = smoothstep(0.11, 0.0, abs(field - radius)) * uReveal * (1.0 - outsideReveal) * (0.22 + uEmber * 0.58);

      vec3 color = tex.rgb;
      color = mix(color, color * vec3(1.04, 1.02, 0.94), 0.12);
      color += (paper - 0.5) * 0.038 * uGrain;
      color += (fineNoise - 0.5) * 0.02 * uGrain;
      if (uIsBackground == 0) {
        float luminance = dot(color, vec3(0.2126, 0.7152, 0.0722));
        float shadowLift = 1.0 - smoothstep(0.08, 0.58, luminance);
        color = mix(color, vec3(0.34, 0.36, 0.32), uLift * shadowLift);
        color = color * 1.04 + vec3(0.018, 0.02, 0.014);
      }
      vec3 pollenEdge = mix(vec3(1.0, 0.9, 0.56), vec3(0.55, 1.0, 0.78), smoothstep(0.62, 1.0, uReveal));
      color = mix(color, pollenEdge, ember * 0.68);
      color += ember * vec3(0.16, 0.18, 0.08);

      float vignette = smoothstep(0.92, 0.12, distance(vScreen, vec2(0.5)));
      if (uIsBackground == 1) {
        color *= mix(0.92, 1.04, vignette);
        color *= 1.04;
      }

      float alpha = sourceAlpha * visible * uOpacity;
      alpha *= 1.0 - ember * 0.18 * (0.65 + uEmber * 0.35);
      if (alpha < 0.01) discard;
      gl_FragColor = vec4(color, alpha);
    }
  `;

  const ATMOSPHERE_VERTEX_SHADER = `
    precision mediump float;
    varying vec2 vUv;
    varying vec2 vScreen;
    void main() {
      vUv = uv;
      vec4 projected = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      vScreen = projected.xy / projected.w * 0.5 + 0.5;
      gl_Position = projected;
    }
  `;

  const ATMOSPHERE_FRAGMENT_SHADER = `
    precision mediump float;
    uniform float uTime;
    uniform float uReveal;
    uniform float uOpacity;
    uniform vec2 uRevealPoint;
    uniform vec2 uPointer;
    varying vec2 vUv;
    varying vec2 vScreen;

    void main() {
      vec2 gridUv = vScreen * vec2(18.0, 10.0);
      vec2 grid = abs(fract(gridUv - 0.5) - 0.5) / fwidth(gridUv);
      float gridLine = 1.0 - min(min(grid.x, grid.y), 1.0);
      float revealHole = smoothstep(uReveal * 1.35 - 0.05, uReveal * 1.35 + 0.08, distance(vScreen, uRevealPoint));
      float verticalMist = smoothstep(0.0, 0.72, vScreen.y) * smoothstep(1.0, 0.38, vScreen.y);
      float alpha = (gridLine * 0.014 + verticalMist * 0.026) * (1.0 - uReveal * 0.85) * revealHole * uOpacity;
      vec3 color = mix(vec3(0.82, 1.0, 0.82), vec3(1.0, 0.82, 0.42), verticalMist * 0.36);
      gl_FragColor = vec4(color, alpha);
    }
  `;

  const PARTICLE_VERTEX_SHADER = `
    precision mediump float;
    uniform float uTime;
    uniform float uReveal;
    uniform float uEmber;
    uniform float uPixelRatio;
    attribute vec3 aVelocity;
    attribute float aSize;
    attribute float aSeed;
    varying float vAlpha;

    void main() {
      vec3 pos = position;
      pos.x += sin(uTime * 0.24 + aSeed) * 0.016;
      pos.y += cos(uTime * 0.18 + aSeed) * 0.012;
      pos += aVelocity * (uReveal * uReveal * 0.72 + uEmber * 0.18);
      vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
      gl_Position = projectionMatrix * mvPosition;
      gl_PointSize = aSize * uPixelRatio * (1.0 + uReveal * 0.85 + uEmber * 0.75);
      vAlpha = (0.52 + sin(aSeed + uTime) * 0.18) * max(1.0 - uReveal, uEmber * 0.58);
    }
  `;

  const PARTICLE_FRAGMENT_SHADER = `
    precision mediump float;
    uniform float uReveal;
    varying float vAlpha;
    void main() {
      vec2 p = gl_PointCoord - 0.5;
      float d = dot(p, p);
      float alpha = smoothstep(0.25, 0.0, d) * vAlpha;
      vec3 color = mix(vec3(1.0, 0.92, 0.62), vec3(0.55, 1.0, 0.76), smoothstep(0.62, 1.0, uReveal));
      gl_FragColor = vec4(color, alpha);
    }
  `;

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootIntro);
  } else {
    bootIntro();
  }
</script>

