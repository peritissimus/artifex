<script>
  import { animate, stagger } from 'animejs';

  // One-shot flourishes. Every animation starts and ends at the identity
  // state, so it can simply run to completion — no snap-back on exit.
  function play(svg: SVGElement) {
    const q = (s: string) => svg.querySelectorAll(s);
    const run: Promise<unknown>[] = [];
    const go = (targets: NodeListOf<Element>, params: Record<string, unknown>) => {
      if (targets.length) run.push(Promise.resolve(animate(targets, params)));
    };
    go(q('.anim-sparkle'), { rotate: [0, 180], scale: [1, 1.25, 1], duration: 750, ease: 'outCubic' });
    go(q('.anim-key'), { translateY: [0, -3.5, 0], duration: 560, delay: stagger(80), ease: 'inOutQuad' });
    go(q('.anim-row'), { translateX: [0, -3.5, 0], duration: 480, delay: stagger(60), ease: 'inOutQuad' });
    go(q('.anim-hands'), { rotate: '1turn', duration: 950, ease: 'inOutCubic' });
    go(q('.anim-orbit'), { rotate: '1turn', duration: 1300, ease: 'inOutSine' });
    go(q('.anim-person'), { translateY: [0, -3, 0], duration: 620, delay: stagger(140), ease: 'inOutSine' });
    go(q('.anim-bird'), { translateY: [0, -3.5, 0], rotate: [0, -8, 0], duration: 650, ease: 'inOutSine' });
    go(q('.anim-float'), { rotate: [0, -3, 0], translateY: [0, -2.5, 0], duration: 800, ease: 'inOutSine' });
    go(q('.anim-chip'), { translateY: [0, -3, 0], duration: 500, delay: stagger(110), ease: 'inOutQuad' });
    go(q('.anim-knob'), { translateX: [0, -7, 0], duration: 700, ease: 'inOutQuad' });
    return run;
  }

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
  document.querySelectorAll<HTMLElement>('.project-card, .software-card').forEach((card) => {
    const svg = card.querySelector<SVGElement>('.project-artwork--card svg');
    if (!svg) return;
    const caret = svg.querySelectorAll('.anim-caret');
    let caretLoop: { cancel: () => void } | null = null;
    let inFlight = false;
    let intent = 0;

    const start = () => {
      if (reduce.matches) return;
      window.clearTimeout(intent);
      // Small hover-intent delay so pass-over mouses don't trigger the show.
      intent = window.setTimeout(() => {
        if (caret.length && !caretLoop)
          caretLoop = animate(caret, { opacity: [1, 0], duration: 430, loop: true, alternate: true, ease: 'inOutSine' });
        if (!inFlight) {
          inFlight = true;
          Promise.allSettled(play(svg)).then(() => {
            inFlight = false;
          });
        }
      }, 90);
    };
    const stop = () => {
      window.clearTimeout(intent);
      // One-shots finish on their own; only the caret loop needs a soft landing.
      if (caretLoop) {
        caretLoop.cancel();
        caretLoop = null;
        animate(caret, { opacity: 1, duration: 180, ease: 'outQuad' });
      }
    };
    card.addEventListener('mouseenter', start);
    card.addEventListener('mouseleave', stop);
    card.addEventListener('focusin', start);
    card.addEventListener('focusout', stop);
  });
</script>
