---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  author?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  ogImage = '/og/home.png',
  ogImageAlt,
  canonicalUrl,
  type = 'website',
  publishedDate,
  author = 'Peritissimus',
  noindex = false,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://peritissimus.com';
const fullOgImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const imageAlt = ogImageAlt ?? title;
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

function normalizeCanonicalUrl(url: string): string {
  const parsed = new URL(url, siteUrl);

  if (parsed.pathname.endsWith('/index.html')) {
    parsed.pathname = parsed.pathname.slice(0, -'/index.html'.length) || '/';
  } else if (parsed.pathname.endsWith('.html')) {
    parsed.pathname = parsed.pathname.slice(0, -'.html'.length);
  }

  parsed.search = '';
  parsed.hash = '';
  return parsed.toString();
}

const fullCanonicalUrl = normalizeCanonicalUrl(canonicalUrl || Astro.url.href);
---

<!-- SEO Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={author} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<link rel="canonical" href={fullCanonicalUrl} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={fullCanonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullOgImageUrl} />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:site_name" content="Peritissimus" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={fullCanonicalUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImageUrl} />
<meta name="twitter:image:alt" content={imageAlt} />

{type === 'article' && publishedDate && (
  <>
    <meta property="article:published_time" content={publishedDate} />
    <meta property="article:author" content={author} />
  </>
)}

<!-- Structured Data (JSON-LD) -->
{jsonLdBlocks.map((block) => (
  <script type="application/ld+json" set:html={JSON.stringify(block)} />
))}
