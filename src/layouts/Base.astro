---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import newsreaderRegularUrl from '@fontsource/newsreader/files/newsreader-latin-400-normal.woff2?url';
import '../styles/main.scss';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogImageAlt?: string;
  currentPath?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  author?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  ogImage,
  ogImageAlt,
  currentPath = Astro.url.pathname,
  type,
  publishedDate,
  author,
  noindex,
  jsonLd,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      type={type}
      publishedDate={publishedDate}
      author={author}
      noindex={noindex}
      jsonLd={jsonLd}
    />

    <!-- RSS feed -->
    <link rel="alternate" type="application/rss+xml" title="Peritissimus — Blog" href="/rss.xml" />

    <!-- Theme adapts to system preference -->
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c0a09" media="(prefers-color-scheme: dark)" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- The display face is used by the logo and the homepage LCP heading. -->
    <link
      rel="preload"
      href={newsreaderRegularUrl}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <!-- Critical inline CSS: sets theme background before the stylesheet loads
         so there is no flash of the wrong theme. -->
    <style is:inline>
      :root {
        color-scheme: light dark;
        --bg: #ffffff;
        --fg: #171717;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0c0a09;
          --fg: #fafaf9;
        }
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        background: var(--bg);
      }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family:
          system-ui,
          -apple-system,
          'Segoe UI',
          Roboto,
          sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
    </style>
  </head>
  <body>
    <Header currentPath={currentPath} />

    <main class="info-wrapper">
      <slot />
    </main>

    <Footer currentPath={currentPath} />
  </body>
</html>
