---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import ProjectArtwork from '../../components/ProjectArtwork.astro';

export async function getStaticPaths() {
  const works = await getCollection('work');
  return works.map((work) => ({
    params: { slug: work.id },
    props: { work },
  }));
}

const { work } = Astro.props;
const { Content } = await render(work);

const personalArtwork = {
  stone: 'memory',
  turntable: 'form',
  birdbrain: 'signal',
  tabbit: 'tabs',
  garatch: 'pulse',
  fitroom: 'fit',
  kaze: 'kaze',
  reelserver: 'reelserver',
  irem: 'irem',
  pymirror: 'pymirror',
} as const;

const artworkVariant = personalArtwork[work.id as keyof typeof personalArtwork];

// Parse markdown bold syntax in achievements
function parseMarkdown(text: string): string {
  return text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
}
---

<Base
  title={`${work.data.title} - ${work.data.kind === 'personal' ? 'Personal Project' : 'Work Experience'}`}
  description={work.data.description}
  ogImage={work.data.ogImage || `/og/work/${work.id}.png`}
  currentPath={`/work/${work.id}`}
>
  <section class:list={['content-section', 'work-detail', { 'work-detail--personal': work.data.kind === 'personal' }]}>
    <div class="section-inner">
      <div class="work-header">
        <div class="work-back">
          <a href={work.data.kind === 'personal' ? '/software' : '/about'}>
            ← {work.data.kind === 'personal' ? 'Back to Personal Software' : 'Back to Timeline'}
          </a>
        </div>
        {work.data.kind === 'personal' && <p class="page-kicker work-kind">Personal project</p>}
        <h1 class="work-company">{work.data.title}</h1>
        <div class="work-meta">
          <span class="work-role">{work.data.role}</span>
          <span class="work-separator">•</span>
          <span class="work-date">{work.data.dateRange}</span>
          <span class="work-separator">•</span>
          <span class="work-location">{work.data.location}</span>
        </div>
        {work.data.externalUrl && (
          <a
            href={work.data.externalUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="work-link"
          >
            {new URL(work.data.externalUrl).hostname} →
          </a>
        )}
        {work.data.kind === 'personal' && artworkVariant && (
          <figure class={`project-blueprint project-blueprint--${work.id}`}>
            <div class="project-blueprint-labels" aria-hidden="true">
              <span>Product study</span>
              <span>Archive {String(work.data.order - 100).padStart(2, '0')}</span>
            </div>
            <ProjectArtwork variant={artworkVariant} detail="blueprint" />
            <figcaption>{work.data.description}</figcaption>
          </figure>
        )}
      </div>

      <div class="work-content">
        <div class="work-section">
          <h3>Overview</h3>
          <Content />
        </div>
      </div>

      {work.data.kind === 'personal' && work.data.screenshot && (
        <figure class:list={['project-screenshot', `project-screenshot--${work.id}`]}>
          <img
            src={work.data.screenshot.src}
            alt={work.data.screenshot.alt}
            width={work.data.screenshot.width}
            height={work.data.screenshot.height}
            loading="lazy"
            decoding="async"
          />
          <figcaption>{work.data.screenshot.caption}</figcaption>
        </figure>
      )}

      <div class="work-content">
        {work.data.achievements.length > 0 && (
          <div class="work-section">
            <h3>Key Achievements</h3>
            <ul class="achievement-list">
              {work.data.achievements.map((achievement) => (
                <li set:html={parseMarkdown(achievement)} />
              ))}
            </ul>
          </div>
        )}

        {work.data.technologies.length > 0 && (
          <div class="work-section">
            <h3>Technologies</h3>
            <div class="tech-grid">
              {work.data.technologies.map((tech) => (
                <span class="tech-tag">{tech}</span>
              ))}
            </div>
          </div>
        )}

        {work.data.stats && work.data.stats.length > 0 && (
          <div class="work-section">
            <h3>Impact</h3>
            <div class="impact-stats">
              {work.data.stats.map((stat) => (
                <div class="stat-item">
                  <div class="stat-value">{stat.value}</div>
                  <div class="stat-label">{stat.label}</div>
                </div>
              ))}
            </div>
          </div>
        )}

        {work.data.outcome && (
          <div class="work-section">
            <h3>Outcome</h3>
            <p>{work.data.outcome}</p>
          </div>
        )}
      </div>
    </div>
  </section>
</Base>
