---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectArtwork from '../components/ProjectArtwork.astro';
import { personSchema } from '../lib/schema';

const selectedWork = (await getCollection('work', ({ data }) => data.kind === 'professional'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const latestPost = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)[0];

const projects = [
  {
    name: 'Stone',
    slug: 'stone',
    description: 'A local-first workspace for notes, meetings, and project memory.',
    className: 'project-card--stone',
    mark: 'memory' as const,
  },
  {
    name: 'Turntable',
    slug: 'turntable',
    description: 'A 3D device mockup tool for creating polished product imagery.',
    className: 'project-card--turntable',
    mark: 'form' as const,
  },
  {
    name: 'Fitroom',
    slug: 'fitroom',
    description: 'An AI try-on studio that renders couples in chosen outfits at true relative height.',
    className: 'project-card--fitroom',
    mark: 'fit' as const,
  },
  {
    name: 'Tabbit',
    slug: 'tabbit',
    description: 'An AI browser extension that groups and tidies crowded tab bars.',
    className: 'project-card--tabbit',
    mark: 'tabs' as const,
  },
  {
    name: 'Garatch',
    slug: 'garatch',
    description: 'Experiments for the wrist, built for Garmin in Monkey C.',
    className: 'project-card--garatch',
    mark: 'pulse' as const,
  },
];
---

<Base
  title="Peritissimus | Kushal Patankar"
  description="Founding engineer and system architect building scalable AI products and infrastructure."
  ogImage="/og/home.png"
  currentPath="/"
  jsonLd={personSchema}
>
  <section class="content-section page-home">
    <div class="section-inner home-inner">
      <div class="home-hero">
        <p class="page-kicker">System architect &amp; engineer</p>
        <h1 class="home-title">I build AI products and the systems that make them scale.</h1>
        <p class="home-intro">
          I’m Kushal Patankar, a founding engineer working across product, infrastructure, and
          applied AI. Currently building tools for local businesses at Zoca.
        </p>
        <div class="home-primary-links" aria-label="Primary links">
          <a href="/about">More about me <span aria-hidden="true">→</span></a>
          <a href="/contact">Get in touch <span aria-hidden="true">→</span></a>
        </div>
      </div>

      <section class="project-deck-section" id="personal-projects" aria-labelledby="projects-heading">
        <div class="home-section-header project-deck-header">
          <h2 id="projects-heading">Personal software</h2>
          <a href="/software">All projects →</a>
        </div>
        <p class="project-deck-intro">
          Small tools and independent experiments I design and build outside of work.
        </p>
        <div class="project-deck">
          {
            projects.map((project) => (
              <a
                class={`project-card ${project.className}`}
                href={`/work/${project.slug}`}
                aria-label={`${project.name}: ${project.description}`}
              >
                <ProjectArtwork variant={project.mark} />
                <span class="project-card-copy">
                  <strong>{project.name}</strong>
                </span>
                <span class="project-card-arrow" aria-hidden="true">→</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="home-section" aria-labelledby="selected-work-heading">
        <div class="home-section-header">
          <h2 id="selected-work-heading">Selected work</h2>
          <span>{selectedWork.length} projects</span>
        </div>
        <div class="home-list">
          {
            selectedWork.map((project) => (
              <a class="home-list-item" href={`/work/${project.id}`}>
                <span class="home-list-title">{project.data.company}</span>
                <span class="home-list-description">{project.data.description}</span>
                <span class="home-list-meta">{project.data.dateRange}</span>
              </a>
            ))
          }
        </div>
      </section>

      {
        latestPost && (
          <section class="home-section" aria-labelledby="latest-writing-heading">
            <div class="home-section-header">
              <h2 id="latest-writing-heading">Latest writing</h2>
            </div>
            <div class="home-list">
              <a class="home-list-item home-writing-item" href={`/blog/${latestPost.id}`}>
                <span class="home-list-title">{latestPost.data.title}</span>
                <span class="home-list-description">{latestPost.data.description}</span>
                <span class="home-list-meta">{latestPost.data.readTime || '5 min read'}</span>
              </a>
            </div>
          </section>
        )
      }

      <p class="home-terminal-link">
        Prefer a command line? <a href="/terminal">Open the interactive terminal →</a>
      </p>
    </div>
  </section>
</Base>
