---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import ProjectArtwork from '../components/ProjectArtwork.astro';

const cardMeta = {
  stone: { className: 'project-card--stone', mark: 'memory' },
  turntable: { className: 'project-card--turntable', mark: 'form' },
  birdbrain: { className: 'project-card--birdbrain', mark: 'signal' },
  tabbit: { className: 'project-card--tabbit', mark: 'tabs' },
  garatch: { className: 'project-card--garatch', mark: 'pulse' },
  fitroom: { className: 'project-card--fitroom', mark: 'fit' },
  strid: { className: 'project-card--strid', mark: 'strid' },
  kaze: { className: 'project-card--kaze', mark: 'kaze' },
  reelserver: { className: 'project-card--reelserver', mark: 'reelserver' },
  irem: { className: 'project-card--irem', mark: 'irem' },
  pymirror: { className: 'project-card--pymirror', mark: 'pymirror' },
} as const;

const projects = (await getCollection('work', ({ data }) => data.kind === 'personal'))
  .filter((work) => work.id in cardMeta)
  .sort((a, b) => {
    if (a.id === 'stone') return -1;
    if (b.id === 'stone') return 1;
    return (b.data.sortDate?.getTime() ?? 0) - (a.data.sortDate?.getTime() ?? 0);
  });
---

<Base
  title="Personal Software - Peritissimus"
  description="Small tools and independent experiments I design and build outside of work."
  ogImage="/og/home.png"
  currentPath="/software"
>
  <section class="content-section page-software">
    <div class="section-inner">
      <header class="software-header">
        <p class="page-kicker">Independent work</p>
        <h1 class="section-title">Personal software</h1>
        <p class="software-intro">
          Small tools and independent experiments I design and build outside of work — local-first
          apps, browser utilities, wearable interfaces, and studios for making things look good.
        </p>
      </header>

      <div class="software-grid">
        {
          projects.map((project) => {
            const meta = cardMeta[project.id as keyof typeof cardMeta];
            return (
              <a
                class={`software-card ${meta.className}`}
                href={`/work/${project.id}`}
                aria-label={`${project.data.title}: ${project.data.description}`}
              >
                <ProjectArtwork variant={meta.mark} />
                <span class="project-card-copy">
                  <span class="project-card-heading">
                    <strong>{project.data.title}</strong>
                    <span class="project-card-date">{project.data.dateRange}</span>
                  </span>
                  <span class="project-card-blurb">{project.data.description}</span>
                </span>
                <span class="project-card-arrow" aria-hidden="true">
                  →
                </span>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>
</Base>
